<script>
async function fetchMatches() {
  const apiURL = "https://your-repl-name.username.repl.co/matches"; // <-- replace with your server URL

  try {
    const response = await fetch(apiURL);
    const matches = await response.json();

    const tbody = document.getElementById("matchesBody");
    tbody.innerHTML = "";

    if (!matches.length) {
      tbody.innerHTML = `<tr><td colspan="5">No matches found for today or tomorrow with favorites ≤ -2000</td></tr>`;
      return;
    }

    matches.forEach(m => {
      const tr = document.createElement("tr");
      const favClass = m.favorite <= -3000 ? "highlight" : "";
      tr.innerHTML = `<td>${m.date}</td><td>${m.event}</td><td>${m.time}</td><td>${m.match}</td><td class="${favClass}">${m.favorite}</td>`;
      tbody.appendChild(tr);
    });

  } catch (err) {
    document.getElementById("matchesBody").innerHTML = `<tr><td colspan="5">Error fetching data: ${err}</td></tr>`;
  }
}

// Fetch immediately
fetchMatches();
</script>
